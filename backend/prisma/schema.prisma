generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id        String   @id @default(uuid())
  type      String   // Tipo de tarea (ej: "batch-images", "pdf-merge", etc.)
  status    String   @default("pending") // pending, processing, completed, failed
  progress  Int      @default(0) // Progreso porcentual (0-100)
  result    String?  // Serializado JSON con datos del resultado
  error     String?  // Mensaje de error si falla
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jobs")
}
